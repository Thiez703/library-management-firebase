rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'librarian'];
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Books & Categories — public read, staff write
    match /books/{bookId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Users — can read/write own data; staff can read all; admin can write all
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId) || isStaff();
      allow update: if (isOwner(userId) &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['role', 'reputationScore', 'isVerified', 'cccdHash']))
                    || isStaff();
      allow delete: if isAdmin();
    }

    // Borrow Records — user can read/create own; staff can read/write all
    match /borrowRecords/{recordId} {
      allow read: if isOwner(resource.data.userId) || isStaff();
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) || isStaff();
      allow update, delete: if isStaff();
    }

    // Fines — user can read own; staff can read/write all
    match /fines/{fineId} {
      allow read: if isOwner(resource.data.userId) || isStaff();
      allow write: if isStaff();
    }

    // Identity collections — write once on register, read by staff or owner
    match /phones/{phone} {
      allow read: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isStaff();
    }

    match /cccds/{cccdHash} {
      allow read: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isStaff();
    }

    match /identityAuditLog/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // System settings — authenticated users can read (needed for borrow limits, fee schedule);
    // only admins can write
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Mail queue — written by functions/triggers; read by admin
    match /mail/{mailId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Reservations — user can read/write own; staff can read all
    match /reservations/{resId} {
      allow read: if isOwner(resource.data.userId) || isStaff();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isStaff();
    }
  }
}
