rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Hàm hỗ trợ ──────────────────────────────────────────────────────────
    
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // ── USERS: Cho phép user tự xem và sửa hồ sơ của mình ───────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── BOOKS: Quan trọng nhất để mượn sách thành công ──────────────────────
    match /books/{bookId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      
      // Cho phép User cập nhật số lượng khi mượn/trả
      allow update: if signedIn();
    }

    // ── CATEGORIES ──────────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── BORROW RECORDS: Phải cho phép User tạo phiếu ────────────────────────
    match /borrowRecords/{recordId} {
      // User xem phiếu của mình, Admin xem tất cả
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      
      // Cho phép User tạo phiếu mượn
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      
      // Chỉ Admin mới được duyệt/sửa/xóa phiếu
      allow update, delete: if isAdmin();
    }

    // ── FINES: Phiếu phạt ───────────────────────────────────────────────────
    match /fines/{fineId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── NOTIFICATIONS ───────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Quy tắc mặc định: Chặn tất cả các truy cập khác ─────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
